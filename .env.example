# =============================================================
# Lighthouse SOC — Example Environment Configuration
# Copy to .env and fill in real values before running.
# Docker compose overrides REDIS_HOST, KAFKA_BROKERS,
# WAZUH_HOST, EVE_JSON_PATH in its environment: blocks.
# =============================================================

# ── Wazuh ────────────────────────────────────────────────────
WAZUH_HOST=localhost
WAZUH_PORT=55000
WAZUH_USERNAME=wazuh
WAZUH_PASSWORD=change-me
WAZUH_VERIFY_SSL=false
WAZUH_ALERT_POLL_INTERVAL=5
WAZUH_REQUEST_TIMEOUT=30
WAZUH_QUEUE_MAXSIZE=1000
WAZUH_ALERTS_SOURCE=container
WAZUH_ALERTS_CONTAINER=wazuh-manager

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_RAW_TOPIC=raw-alerts

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Threat Intelligence ───────────────────────────────────────
# Get a free key at https://www.abuseipdb.com/
ABUSEIPDB_API_KEY=your-abuseipdb-key-here

# ── GeoIP / Asset DB ──────────────────────────────────────────
GEOIP_DB_PATH=data/GeoLite2-City.mmdb
GEOIP_DATABASE_PATH=data/GeoLite2-City.mmdb
ASSET_DB_PATH=data/asset_db.json

# ── Dataset / Sigma Paths ─────────────────────────────────────
CIC_DATASET_PATH=data/raw/cic2017
SIGMA_RULES_DIR=detection/sigma_rules

# ── ML Models ─────────────────────────────────────────────────
MODEL_DIR=data/models
ML_MODEL_PATH=data/models/cic2017_pipeline_smote.joblib
CIC_MODEL_PATH=data/models/cic2017_pipeline_smote.joblib
UNSW_MODEL_PATH=data/models/unsw_nb15_pipeline.joblib
ANOMALY_MODEL_THRESHOLD=0.05
DETECTION_BATCH_SIZE=128

# ── GPU (only used during training) ──────────────────────────
CUDA_VISIBLE_DEVICES=0
GPU_BATCH_SIZE=512
GPU_WORKERS=4

# ── Suricata eve.json path ────────────────────────────────────
# Leave empty for local dev (seeds mock alerts instead)
# Docker sets this to /var/log/suricata/eve.json via environment:
EVE_JSON_PATH=

# ── SOAR ──────────────────────────────────────────────────────
# Set to 0 in production (requires root for iptables)
SOAR_DRY_RUN=1

# ── Dev mode ──────────────────────────────────────────────────
LIGHTHOUSE_DEV=1

# ── LLM Assistant ─────────────────────────────────────────────
# Options: groq | openai | ollama_cloud | ollama
LLM_PROVIDER=ollama_cloud
LLM_API_KEY=your-ollama-cloud-key-here
LLM_MODEL=gemma3:4b
